# FastAPI
APP_TITLE=FastAPI Social Task

# PostgreSQL
# Example: postgresql+psycopg://user:password@localhost:5432/fastapi_task
DATABASE_URL=

# JWT
JWT_ALGORITHM=HS256
JWT_SECRET=CHANGE_ME

# Optional RSA (only needed if JWT_ALGORITHM=RS256)
# JWT_PRIVATE_KEY_PEM="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
# JWT_PUBLIC_KEY_PEM="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"

ACCESS_TOKEN_EXPIRE_MINUTES=60

